MINIO_REGION=ru-3
MINIO_BUCKET=analytics
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_OBJECT_PREFIX=

# S3/MinIO export for jobs/features_etl.py
S3_ENDPOINT_URL=https://s3.ru-3.storage.selcloud.ru
S3_REGION=ru-3
S3_BUCKET=final-project-nova-data
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_OBJECT_PREFIX=

# Fernet key (generate before run)
