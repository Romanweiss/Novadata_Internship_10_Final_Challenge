PROJECT_NAME=probablyfresh-analytics-platform

# Data generation
DATA_DIR=./data
STORES_ALMOST_COUNT=30
STORES_MAYBE_COUNT=15
PRODUCTS_PER_CATEGORY=20
CUSTOMERS_PER_STORE=1
PURCHASES_COUNT=200
RANDOM_SEED=42

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin
MONGO_DB=probablyfresh
MONGO_URI=mongodb://admin:admin@localhost:27017/probablyfresh?authSource=admin

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_CLIENT_ID=probablyfresh-producer
KAFKA_TOPIC_STORES=probablyfresh.stores
KAFKA_TOPIC_PRODUCTS=probablyfresh.products
KAFKA_TOPIC_CUSTOMERS=probablyfresh.customers
KAFKA_TOPIC_PURCHASES=probablyfresh.purchases

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DB=probablyfresh_raw
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Spark features ETL (ClickHouse JDBC)
CH_HOST=clickhouse
CH_PORT=8123
CH_USER=default
CH_PASSWORD=
CH_DATABASE=probablyfresh_mart
SPARK_MASTER=local[*]

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
TELEGRAM_BOT_TOKEN=

# MinIO/S3 export for jobs/features_etl.py (preferred names)
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=ru-3
MINIO_BUCKET=analytics
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_OBJECT_PREFIX=

# S3/MinIO export for jobs/features_etl.py
S3_ENDPOINT_URL=https://s3.ru-3.storage.selcloud.ru
S3_REGION=ru-3
S3_BUCKET=final-project-nova-data
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_OBJECT_PREFIX=

# Fernet key (generate before run)
